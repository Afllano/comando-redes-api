# ============================================================
#  Comando Redes - variables de entorno
#  Copia este archivo como .env y llena lo que vayas activando.
#  Nada de esto se sube a Git (ver .gitignore).
# ============================================================

# Puerto del servidor (Render/Railway lo asignan solos)
PORT=8787

# Origen permitido del frontend (tu app en Vercel)
CORS_ORIGIN=http://localhost:5173

# ---- IA (obligatorio para auditorias y generacion) ----
# Consíguela en https://console.anthropic.com  (tiene saldo de prueba gratis)
ANTHROPIC_API_KEY=

# ---- Meta (Instagram + Facebook) ----
# App en https://developers.facebook.com  (gratis). Requiere revision de Meta para publicar.
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:8787/auth/meta/callback

# ---- Google Analytics 4 (reportes reales) ----
# Crea un Service Account en Google Cloud (gratis) y dale acceso de lectura a tu propiedad GA4.
# Pega aqui el JSON del service account en una sola linea, o usa GOOGLE_APPLICATION_CREDENTIALS con la ruta del archivo.
GOOGLE_APPLICATION_CREDENTIALS=
GA_SERVICE_ACCOUNT_JSON=

# ---- TikTok / LinkedIn (fase posterior) ----
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
